# AutoAgent VNextCC — Environment Variables
# Copy to .env and fill in values: cp .env.example .env

# =============================================================================
# API Keys (at least one required for non-mock optimization)
# =============================================================================
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# =============================================================================
# Database Paths (all optional — sensible defaults used)
# =============================================================================
# AUTOAGENT_DB=conversations.db
# AUTOAGENT_CONFIGS=configs
# AUTOAGENT_MEMORY_DB=optimizer_memory.db
# AUTOAGENT_REGISTRY_DB=registry.db
# AUTOAGENT_TRACE_DB=traces.db
# AUTOAGENT_EVAL_HISTORY_DB=eval_history.db

# =============================================================================
# Server Configuration
# =============================================================================
# HOST=0.0.0.0
# PORT=8000

# =============================================================================
# Logging
# =============================================================================
# LOG_LEVEL=INFO
# PYTHONUNBUFFERED=1
